<Application x:Class="CybersecurityBotWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="Button" x:Key="QuickButtonStyle">
            <Setter Property="Background" Value="#0F3460"/>
            <Setter Property="Foreground" Value="#4ECDC4"/>
            <Setter Property="BorderBrush" Value="#4ECDC4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4ECDC4"/>
                    <Setter Property="Foreground" Value="#1A1A2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>