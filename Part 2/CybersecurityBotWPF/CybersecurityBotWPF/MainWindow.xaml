<Window x:Class="CybersecurityBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" 
        Height="750" Width="1000"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- White & Purple Color Theme -->
        <SolidColorBrush x:Key="PrimaryWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryPurple" Color="#9B59B6"/>
        <SolidColorBrush x:Key="LightPurple" Color="#D5B4E6"/>
        <SolidColorBrush x:Key="DarkPurple" Color="#6C3483"/>
        <SolidColorBrush x:Key="BotMessageBrush" Color="#D5B4E6"/>
        <SolidColorBrush x:Key="UserMessageBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#2C2C3E"/>
        <SolidColorBrush x:Key="SendButtonBrush" Color="#9B59B6"/>
        <SolidColorBrush x:Key="ClearButtonBrush" Color="#E74C3C"/>

        <Style TargetType="Button" x:Key="QuickButtonStyle">
            <Setter Property="Background" Value="#2C2C3E"/>
            <Setter Property="Foreground" Value="#D5B4E6"/>
            <Setter Property="BorderBrush" Value="#9B59B6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9B59B6"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art -->
        <Border Grid.Row="0" Background="#2C2C3E" BorderBrush="#9B59B6" BorderThickness="0,0,0,2">
            <Grid>
                <Border Background="#1A1A2E" Margin="20,15,20,10" CornerRadius="10" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        BorderBrush="#9B59B6" BorderThickness="1">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" 
                                  VerticalScrollBarVisibility="Disabled"
                                  MaxHeight="250">
                        <TextBlock x:Name="AsciiArtTextBlock" 
                                   FontFamily="Consolas" 
                                   FontSize="11" 
                                   Foreground="#D5B4E6"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap"
                                   Background="#1A1A2E"
                                   Padding="15,10,15,10"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- User Greeting Section -->
        <Border Grid.Row="1" Background="#2C2C3E" Margin="20,15,20,10" CornerRadius="10" Padding="15"
                BorderBrush="#9B59B6" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Welcome, " FontSize="16" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                <TextBox x:Name="UserNameBox" 
                         Text="Guest" 
                         Width="150" 
                         Margin="5,0"
                         Background="#1A1A2E"
                         Foreground="#FFFFFF"
                         BorderBrush="#9B59B6"
                         FontSize="14"
                         Padding="8,5"/>
                <Button x:Name="SetNameButton" 
                        Content="Set Name" 
                        Background="#9B59B6" 
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="15,8"
                        Margin="5,0"
                        Cursor="Hand"
                        FontWeight="Bold"
                        Click="SetNameButton_Click"/>
                <Button x:Name="PlayVoiceButton" 
                        Content="🔊 Play Greeting" 
                        Background="#6C3483" 
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="15,8"
                        Margin="5,0"
                        Cursor="Hand"
                        FontWeight="Bold"
                        Click="PlayVoiceButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Chat Messages Area -->
        <ScrollViewer Grid.Row="2" 
                      x:Name="ChatScrollViewer"
                      Background="#1A1A2E"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ChatMessagesPanel" 
                        Margin="20,10,20,10"
                        Background="#1A1A2E"/>
        </ScrollViewer>

        <!-- Quick Topic Buttons -->
        <Border Grid.Row="3" Background="#2C2C3E" Padding="15" Margin="20,5,20,5" CornerRadius="10"
                BorderBrush="#9B59B6" BorderThickness="1">
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="🔐 Password Safety" Style="{StaticResource QuickButtonStyle}" Click="QuickTopic_Click" Margin="5"/>
                <Button Content="🎣 Phishing Scams" Style="{StaticResource QuickButtonStyle}" Click="QuickTopic_Click" Margin="5"/>
                <Button Content="🌐 Safe Browsing" Style="{StaticResource QuickButtonStyle}" Click="QuickTopic_Click" Margin="5"/>
                <Button Content="🛡️ Malware" Style="{StaticResource QuickButtonStyle}" Click="QuickTopic_Click" Margin="5"/>
                <Button Content="🔑 MFA/2FA" Style="{StaticResource QuickButtonStyle}" Click="QuickTopic_Click" Margin="5"/>
                <Button Content="💾 Backups" Style="{StaticResource QuickButtonStyle}" Click="QuickTopic_Click" Margin="5"/>
                <Button Content="🧠 Social Engineering" Style="{StaticResource QuickButtonStyle}" Click="QuickTopic_Click" Margin="5"/>
                <Button Content="🆔 Identity Theft" Style="{StaticResource QuickButtonStyle}" Click="QuickTopic_Click" Margin="5"/>
            </WrapPanel>
        </Border>

        <!-- Message Input Area -->
        <Border Grid.Row="4" Background="#2C2C3E" Padding="15" Margin="20,5,20,20" CornerRadius="10"
                BorderBrush="#9B59B6" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageInputBox" 
                         Grid.Column="0"
                         Background="#1A1A2E"
                         Foreground="#FFFFFF"
                         BorderBrush="#9B59B6"
                         FontSize="14"
                         Padding="12,10"
                         VerticalContentAlignment="Center"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="Auto"
                         MinHeight="40"
                         KeyDown="MessageInputBox_KeyDown"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button x:Name="SendButton" 
                            Content="📤 Send" 
                            Background="#9B59B6" 
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="20,10"
                            Margin="5,0"
                            Cursor="Hand"
                            FontWeight="Bold"
                            Click="SendButton_Click"/>
                    <Button x:Name="ClearButton" 
                            Content="🗑️ Clear" 
                            Background="#E74C3C" 
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="20,10"
                            Margin="5,0"
                            Cursor="Hand"
                            Click="ClearButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>